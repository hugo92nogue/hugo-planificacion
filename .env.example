# Copiá este archivo como ".env" y completá con los datos de TU proyecto Supabase.
# (Settings -> API en el panel de Supabase)
# El archivo .env NO se sube al repo (está en .gitignore).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_PUBLIC_KEY

# Acceso libre (sin pantalla de login): la app entra sola con esta cuenta oculta.
# Poné cualquier email (no hace falta que sea real) y una contraseña de 6+ caracteres.
# Requiere tener "Confirm email" DESACTIVADO en Supabase (Authentication -> Providers -> Email).
VITE_APP_EMAIL=acceso@hugo.app
VITE_APP_PASSWORD=cambia-esta-clave
